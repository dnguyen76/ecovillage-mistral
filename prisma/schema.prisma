generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
}

model UserEcovillage {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  role         String        @default("user")
  mistralKey   String        @default("")
  createdAt    DateTime      @default(now())
  sessions          QuizSession[]
  ecovillageSessions EcovillageSession[]

  @@map("user_ecovillage")
}

model QuizSession {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        UserEcovillage @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String
  completedAt DateTime       @default(now())

  answersAgriculteurs Json
  answersIndustriels  Json
  answersHabitants    Json
  answersElus         Json

  summaryAgriculteurs String @default("")
  summaryIndustriels  String @default("")
  summaryHabitants    String @default("")
  summaryElus         String @default("")

  @@map("quiz_session")
}

model EcovillageSession {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        UserEcovillage @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String
  completedAt DateTime       @default(now())

  // Réponses complètes par groupe (JSON)
  answersAgriculteurs Json   @default("[]")
  answersIndustriels  Json   @default("[]")
  answersHabitants    Json   @default("[]")
  answersElus         Json   @default("[]")

  // Résumé texte des choix par groupe
  summaryAgriculteurs String @default("")
  summaryIndustriels  String @default("")
  summaryHabitants    String @default("")
  summaryElus         String @default("")

  // Images générées (base64)
  imageAvant  String @default("")
  imageApres  String @default("")

  // Bilan IA Mistral
  bilanMistral String @default("")

  @@map("ecovillage_session")
}
